<Window
    x:Class="Practika2_OPAM_Ubohyi_Stanislav.SortProgram"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="clr-namespace:Practika2_OPAM_Ubohyi_Stanislav.Pages"
    xmlns:local="clr-namespace:Practika2_OPAM_Ubohyi_Stanislav"
    xmlns:conv="clr-namespace:Practika2_OPAM_Ubohyi_Stanislav.Converters"
    Title="AlgoStart"
    Width="1260"
    Height="800"
    WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Верхня панель з назвою програми та кнопками управління вікном -->
        <Border
            Classes="titleBar"
            DockPanel.Dock="Top">
            <Grid>
                <TextBlock 
                    Text="AlgoStart"
                    Foreground="#FFFFFF"
                    FontSize="16"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="15,0,0,0"/>
                <Grid HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Кнопка мінімізації вікна -->
                    <Button 
                        Grid.Column="0"
                        Name="MinimizeButton"
                        Classes="titleBarButton"
                        Click="MinimizeWindow">
                        <TextBlock Text="−" FontFamily="Segoe UI" Margin="0,0,0,0"/>
                    </Button>
                    
                    <!-- Кнопка максимізації вікна -->
                    <Button 
                        Grid.Column="1"
                        Name="MaximizeButton"
                        Classes="titleBarButton"
                        Click="MaximizeWindow">
                        <TextBlock Text="□" FontFamily="Segoe UI" Margin="0,-7,0,0"/>
                    </Button>
                    
                    <!-- Кнопка закриття вікна -->
                    <Button 
                        Grid.Column="2"
                        Name="CloseButton"
                        Classes="titleBarButton closeButton"
                        Click="CloseWindow">
                        <TextBlock Text="×" FontFamily="Segoe UI" Margin="0,0,0,0"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>   

        <!-- Бічне меню навігації -->
        <Grid Classes="sideMenu" DockPanel.Dock="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Логотип та назва -->
            <StackPanel Grid.Row="0" Margin="15,15,0,20">
                <TextBlock Name="AppTitle" Text="SortProgram" FontWeight="Bold" Foreground="#E0E0E0" FontSize="16" Classes="navText" />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <!-- Кнопка для переходу на головну сторінку -->
                <Button Name="HomeButton" Classes="navButton" Click="NavigateToHome">
                    <DockPanel LastChildFill="True">
                        <TextBlock Classes="navIcon" Text="🏡" />
                        <TextBlock Classes="navText" Text="Home" />
                    </DockPanel>
                </Button>

                <!-- Кнопка для переходу на сторінку списку таблиць -->
                <Button Name="SortingButton" Classes="navButton" Click="NavigateToSorting">
                    <DockPanel LastChildFill="True">
                        <TextBlock Classes="navIcon" Text="📈" />
                        <TextBlock Classes="navText" Text="Sorting" />
                    </DockPanel>
                </Button>

                <!-- Кнопка для переходу на сторінку статистики -->
                <Button Name="StatisticsButton" Classes="navButton" Click="NavigateToStaticks">
                    <DockPanel LastChildFill="True">
                        <TextBlock Classes="navIcon" Text="📊" />
                        <TextBlock Classes="navText" Text="Statistics" />
                    </DockPanel>
                </Button>

                <!-- Кнопка для переходу на сторінку налаштувань -->
                <Button Name="SettingsButton" Classes="navButton" Click="NavigateToSettings">
                    <DockPanel LastChildFill="True">
                        <TextBlock Classes="navIcon" Text="🔧" />
                        <TextBlock Classes="navText" Text="Settings" />
                    </DockPanel>
                </Button>
            </StackPanel>

            <!-- Нижні кнопки -->
            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <!-- Кнопка перемикання теми -->
                <Button Name="ThemeButton" Classes="navButton" Click="ToggleTheme">
                    <DockPanel LastChildFill="True">
                        <TextBlock Name="ThemeIcon" Classes="navIcon" Text="☀️" />
                        <TextBlock Name="ThemeText" Classes="navText" Text="Light Theme" />
                    </DockPanel>
                </Button>
                
                <!-- Кнопка для виходу з програми -->
                <Button Classes="navButton" Click="ExitButton_Click">
                    <DockPanel LastChildFill="True">
                        <TextBlock Classes="navIcon" Text="🚪" />
                        <TextBlock Classes="navText" Text="Logout" />
                    </DockPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Основний вміст сторінки -->
        <Grid Name="MainContentGrid" Classes="ThemeLight">
            <ContentControl Name="PageContent" />
        </Grid>
    </DockPanel>
</Window>