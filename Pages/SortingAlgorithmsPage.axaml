<UserControl
    x:Class="Practika2_OPAM_Ubohyi_Stanislav.Pages.SortingAlgorithmsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="30">
            <!-- Article 1 -->
            <Border Classes="fluentCard" Margin="0,10,0,20" CornerRadius="10" BoxShadow="0 4 8 #20000000">
                <Grid ColumnDefinitions="*, Auto">
                    <!-- Текст статті -->
                    <StackPanel Grid.Column="0" Margin="20,15,10,15" VerticalAlignment="Center">
                        <TextBlock Text="Bubble Sort" FontSize="36" FontWeight="SemiBold" Margin="0,0,0,10" 
                                   FontFamily="{StaticResource OswaldFont}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">Бульбашкове сортування - це простий алгоритм сортування, який неодноразово переглядає список, порівнює сусідні елементи і міняє їх місцями, якщо вони в неправильному порядку.</TextBlock>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Learn More" Classes="infoButton" CornerRadius="5" Padding="12,8" 
                                    Width="120" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                            <Button Content="Переглянути демо" Classes="successButton" CornerRadius="5" Padding="12,8" 
                                    Width="170" HorizontalAlignment="Left" Margin="0,10,0,0" 
                                    Click="ViewArticleDemo_Click"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Зображення статті -->
                    <Border Grid.Column="1" Margin="10,15,20,15" Width="200" Height="150" CornerRadius="5" 
                            ClipToBounds="True" BoxShadow="0 2 4 #20000000">
                        <Image Source="avares://Practika2_OPAM_Ubohyi_Stanislav/Image/bubble_sort.gif" 
                               Stretch="UniformToFill"/>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Article 2 -->
            <Border Classes="fluentCard" Margin="0,10,0,20" CornerRadius="10" BoxShadow="0 4 8 #20000000">
                <Grid ColumnDefinitions="*, Auto">
                    <!-- Текст статті -->
                    <StackPanel Grid.Column="0" Margin="20,15,10,15" VerticalAlignment="Center">
                        <TextBlock Text="Selection Sort" FontSize="36" FontWeight="SemiBold" Margin="0,0,0,10" 
                                   FontFamily="{StaticResource OswaldFont}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">Сортування вибором - це алгоритм сортування порівнянням, який розділяє вхідний список на дві частини: відсортований підсписок і невідсортований підсписок. Знаходить найменший елемент і переміщує його на початок.</TextBlock>
                        <Button Content="Learn More" Classes="infoButton" CornerRadius="5" Padding="12,8" 
                                Width="120" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                    </StackPanel>
                    
                    <!-- Зображення статті -->
                    <Border Grid.Column="1" Margin="10,15,20,15" Width="200" Height="150" CornerRadius="5" 
                            ClipToBounds="True" BoxShadow="0 2 4 #20000000">
                        <Image Source="avares://Practika2_OPAM_Ubohyi_Stanislav/Image/selection_sort.gif" 
                               Stretch="UniformToFill"/>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Article 3 -->
            <Border Classes="fluentCard" Margin="0,10,0,20" CornerRadius="10" BoxShadow="0 4 8 #20000000">
                <Grid ColumnDefinitions="*, Auto">
                    <!-- Текст статті -->
                    <StackPanel Grid.Column="0" Margin="20,15,10,15" VerticalAlignment="Center">
                        <TextBlock Text="Quick Sort" FontSize="36" FontWeight="SemiBold" Margin="0,0,0,10" 
                                   FontFamily="{StaticResource OswaldFont}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">Швидке сортування - це алгоритм "розділяй і володарюй", який працює шляхом вибору опорного елемента і поділу масиву навколо нього так, щоб елементи, менші за опорний, були зліва, а більші - справа.</TextBlock>
                        <Button Content="Learn More" Classes="infoButton" CornerRadius="5" Padding="12,8" 
                                Width="120" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                    </StackPanel>
                    
                    <!-- Зображення статті -->
                    <Border Grid.Column="1" Margin="10,15,20,15" Width="200" Height="150" CornerRadius="5" 
                            ClipToBounds="True" BoxShadow="0 2 4 #20000000">
                        <Image Source="avares://Practika2_OPAM_Ubohyi_Stanislav/Image/quick_sort.gif" 
                               Stretch="UniformToFill"/>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
