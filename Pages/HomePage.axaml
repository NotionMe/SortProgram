<UserControl
    x:Class="Practika2_OPAM_Ubohyi_Stanislav.Pages.HomePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel Spacing="20" Margin="20">
            <Border Background="#FFFFFF"
                    Width="1060" Height="161"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,10"
                    BoxShadow="0 0 14.1 4 #40000000">
                <TextBlock Text="Interactive reference book Basics of Algorithms" 
                           FontSize="48"
                           FontFamily="{StaticResource OswaldFont}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
            </Border>
            
            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,10">
                <Border Grid.Column="0" Grid.Row="0" Background="#B80C294B" CornerRadius="20" Width="221" Height="41" Margin="0,0,5,0" HorizontalAlignment="Center">
                    <TextBlock Text="Bubble Sort" Foreground="#FFFFFF" FontFamily="Inter" FontWeight="Bold" FontStyle="Italic" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="1" Grid.Row="0" Background="#B80C294B" CornerRadius="20" Width="221" Height="41" Margin="5,0,5,0" HorizontalAlignment="Center">
                    <TextBlock Text="Selection Sort" Foreground="#FFFFFF" FontFamily="Inter" FontWeight="Bold" FontStyle="Italic" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="2" Grid.Row="0" Background="#B80C294B" CornerRadius="20" Width="221" Height="41" Margin="5,0,5,0" HorizontalAlignment="Center">
                    <TextBlock Text="Quick Sort" Foreground="#FFFFFF" FontFamily="Inter" FontWeight="Bold" FontStyle="Italic" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="3" Grid.Row="0" Background="#B80C294B" CornerRadius="20" Width="221" Height="41" Margin="5,0,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="Insertion Sort" Foreground="#FFFFFF" FontFamily="Inter" FontWeight="Bold" FontStyle="Italic" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <!-- Algorithm Visualizations -->
                <Border Grid.Column="0" Grid.Row="1" Background="White" CornerRadius="8" Margin="0,15,5,15" Width="220" Height="150">
                    <Image Name="BubbleSortImage" Source="avares://Practika2_OPAM_Ubohyi_Stanislav/Image/bubble_sort.gif" Stretch="Uniform" Margin="5"/>
                </Border>
                
                <Border Grid.Column="1" Grid.Row="1" Background="White" CornerRadius="8" Margin="5,15,5,15" Width="220" Height="150">
                    <Image Name="SelectionSortImage" Source="avares://Practika2_OPAM_Ubohyi_Stanislav/Image/selection_sort.gif" Stretch="Uniform" Margin="5"/>
                </Border>
                
                <Border Grid.Column="2" Grid.Row="1" Background="White" CornerRadius="8" Margin="5,15,5,15" Width="220" Height="150">
                    <Image Name="QuickSortImage" Source="avares://Practika2_OPAM_Ubohyi_Stanislav/Image/quick_sort.gif" Stretch="Uniform" Margin="5"/>
                </Border>
                
                <Border Grid.Column="3" Grid.Row="1" Background="White" CornerRadius="8" Margin="5,15,0,15" Width="220" Height="150">
                    <Image Name="InsertionSortImage" Source="avares://Practika2_OPAM_Ubohyi_Stanislav/Image/insertion_sort.gif" Stretch="Uniform" Margin="5"/>
                </Border>

                <!-- Algorithm Descriptions -->
                <Border Grid.Column="0" Grid.Row="2" Background="White" CornerRadius="8" Margin="0,5,5,15" Width="220" BoxShadow="0 4 4 #40000000">
                    <TextBlock TextWrapping="Wrap" Margin="10" FontSize="14" FontFamily="Inter" FontWeight="Bold" FontStyle="Italic" TextAlignment="Center">
                        <Run Text="Bubble Sort" Foreground="#0C294B" FontSize="16"/>
                        <LineBreak/>
                        <Run Text="A simple sorting algorithm that repeatedly steps through the list, compares adjacent elements and swaps them if they are in the wrong order. The pass through the list is repeated until the list is sorted."/>
                    </TextBlock>
                </Border>

                <Border Grid.Column="1" Grid.Row="2" Background="White" CornerRadius="8" Margin="5,5,5,15" Width="220" BoxShadow="0 4 4 #40000000">
                    <TextBlock TextWrapping="Wrap" Margin="10" FontSize="14" FontFamily="Inter" FontWeight="Bold" FontStyle="Italic" TextAlignment="Center">
                        <Run Text="Selection Sort" Foreground="#0C294B" FontSize="16"/>
                        <LineBreak/>
                        <Run Text="A comparison sorting algorithm that divides the input list into two parts: a sorted sublist and an unsorted sublist. It finds the smallest element and moves it to the beginning."/>
                    </TextBlock>
                </Border>

                <Border Grid.Column="2" Grid.Row="2" Background="White" CornerRadius="8" Margin="5,5,5,15" Width="220" BoxShadow="0 4 4 #40000000">
                    <TextBlock TextWrapping="Wrap" Margin="10" FontSize="14" FontFamily="Inter" FontWeight="Bold" FontStyle="Italic" TextAlignment="Center">
                        <Run Text="Quick Sort" Foreground="#0C294B" FontSize="16"/>
                        <LineBreak/>
                        <Run Text="A divide-and-conquer algorithm that works by selecting a 'pivot' element and partitioning the array around it, so that elements smaller than the pivot are on the left and larger ones are on the right."/>
                    </TextBlock>
                </Border>

                <Border Grid.Column="3" Grid.Row="2" Background="White" CornerRadius="8" Margin="5,5,0,15" Width="220" BoxShadow="0 4 4 #40000000">
                    <TextBlock TextWrapping="Wrap" Margin="10" FontSize="14" FontFamily="Inter" FontWeight="Bold" FontStyle="Italic" TextAlignment="Center">
                        <Run Text="Insertion Sort" Foreground="#0C294B" FontSize="16"/>
                        <LineBreak/>
                        <Run Text="Builds the final sorted array one item at a time. Efficient for small data sets and is often used as part of more sophisticated algorithms."/>
                    </TextBlock>
                </Border>
                <!-- Info Buttons -->
                <Button Grid.Column="0" Grid.Row="3" Content="Info" Width="177" Height="32" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#666666" Foreground="White" CornerRadius="20"
                        FontFamily="{StaticResource AnonymousPro}"
                        FontWeight="Regular" Margin="0,0,5,15" FontSize="20"
                        HorizontalContentAlignment="Center"/>
                
                <Button Grid.Column="1" Grid.Row="3" Content="Info" Width="177" Height="32" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#666666" Foreground="White" CornerRadius="20"
                        FontFamily="{StaticResource AnonymousPro}"
                        FontWeight="Regular" Margin="5,0,5,15" FontSize="20"
                        HorizontalContentAlignment="Center"/>
                
                <Button Grid.Column="2" Grid.Row="3" Content="Info" Width="177" Height="32" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#666666" Foreground="White" CornerRadius="20"
                        FontFamily="{StaticResource AnonymousPro}"
                        FontWeight="Regular" Margin="5,0,5,15" FontSize="20"
                        HorizontalContentAlignment="Center"/>
                
                <Button Grid.Column="3" Grid.Row="3" Content="Info" Width="177" Height="32" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#666666" Foreground="White" CornerRadius="20"
                        FontFamily="{StaticResource AnonymousPro}"
                        FontWeight="Regular" Margin="5,0,0,15" FontSize="20"
                        HorizontalContentAlignment="Center"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
