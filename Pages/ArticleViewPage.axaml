<UserControl
    x:Class="Practika2_OPAM_Ubohyi_Stanislav.Pages.ArticleViewPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="1050" Height="800">

    <Grid>
        <Border
            Margin="20"
            Background="{DynamicResource ThemeBackgroundBrush}"
            BoxShadow="0 3 10 #40000000"
            CornerRadius="8">
            <Grid Margin="30,30,30,20" RowDefinitions="Auto,*">
                <!--  Заголовок статті  -->
                <TextBlock
                    Grid.Row="0"
                    Margin="0,10,0,20"
                    HorizontalAlignment="Center"
                    FontSize="42"
                    FontWeight="Bold"
                    Foreground="{DynamicResource ThemeForegroundBrush}"
                    Text="Bubble Sort" />

                <!--  Основний контент статті  -->
                <Grid Grid.Row="1" 
                     RowDefinitions="*,Auto" 
                     ColumnDefinitions="*, Auto">
                    <!--  Текст статті  -->
                    <Border 
                        Grid.Column="0"
                        Grid.Row="0"
                        Width="727" 
                        Height="520"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="0,0,20,0">
                        <TextBlock
                            Margin="0"
                            FontSize="24"
                            LineHeight="24"
                            TextAlignment="Justify"
                            TextWrapping="Wrap"
                            Foreground="{DynamicResource ThemeForegroundBrush}">
Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor

Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor

Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor Lorem ipsum sit amet dolor, Lorem ipsum sit amet dolor,Lorem ipsum sit amet dolor
                        </TextBlock>
                    </Border>

                    <!--  Зображення статті (справа вгорі)  -->
                    <Border
                        Grid.Column="1"
                        Grid.Row="0"
                        Width="220"
                        Height="180"
                        VerticalAlignment="Top"
                        Margin="10,0,0,0"
                        ClipToBounds="True"
                        CornerRadius="5">
                        <Image Source="avares://Practika2_OPAM_Ubohyi_Stanislav/Image/bubble_sort.gif" Stretch="UniformToFill" />
                    </Border>

                    <!--  Навігаційні кнопки  -->
                    <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,15,0,0">
                        <Button
                            Width="65"
                            Height="65"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource PrimaryBrush}"
                            BorderThickness="0"
                            CornerRadius="32"
                            Cursor="Hand"
                            Margin="5,0,0,0"
                            Click="BackButton_Click">
                            <TextBlock
                                Margin="0,0,0,5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Foreground="White"
                                Text="←" />
                        </Button>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0"
                            FontSize="100"
                            FontWeight="Bold"
                            Foreground="{DynamicResource ThemePageNumberBrush}"
                            Opacity="0.5"
                            Text="01" />

                        <Button
                            Width="65"
                            Height="65"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource PrimaryBrush}"
                            BorderThickness="0"
                            CornerRadius="32"
                            Cursor="Hand"
                            Margin="0,0,20,0"
                            Click="NextButton_Click">
                            <TextBlock
                                Margin="0,0,0,5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Foreground="White"
                                Text="→" />
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
