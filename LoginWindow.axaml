<Window
    x:Class="Practika2_OPAM_Ubohyi_Stanislav.LoginWindow.LoginWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Login"
    d:DesignHeight="450"
    d:DesignWidth="400"
    ExtendClientAreaTitleBarHeightHint="-1"
    ExtendClientAreaToDecorationsHint="True"
    Foreground="#333"
    SystemDecorations="None"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0.0" Color="#E0F2FF" />
            <GradientStop Offset="1.0" Color="#FFFFFF" />
        </LinearGradientBrush>
    </Window.Background>


    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Button.login">
            <Setter Property="Padding" Value="10,12" />
            <Setter Property="Margin" Value="0,15,0,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#007AFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.login:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0056b3" />
        </Style>
        <Style Selector="Button.titleBarButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#505050" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.titleBarButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E0E0E0" />
        </Style>
        <Style Selector="Button.closeButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Padding" Value="10,10" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D0D0D0" />
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">

        <Border
            Height="30"
            Background="Transparent"
            DockPanel.Dock="Top">
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="1">
                <Button
                    Name="MinimizeButton"
                    Classes="titleBarButton"
                    Click="MinimizeWindow"
                    Content="_" />
                <Button
                    Name="MaximizeButton"
                    Classes="titleBarButton"
                    Click="MaximizeWindow"
                    Content="□" />
                <Button
                    Name="CloseButton"
                    Classes="titleBarButton closeButton"
                    Click="CloseWindow"
                    Content="X" />
            </StackPanel>
        </Border>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border
                Width="320"
                Margin="0,0,0,20"
                Padding="30"
                Background="White"
                BoxShadow="0 6 15 #20000000"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        FontSize="24"
                        FontWeight="Bold"
                        Text="Вхід" />

                    <TextBlock
                        FontSize="12"
                        Foreground="Gray"
                        Text="Ім'я користувача" />
                    <TextBox Name="UsernameTextBox" Watermark="Введіть логін" />

                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="12"
                        Foreground="Gray"
                        Text="Електронна пошта" />
                    <TextBox Name="EmailTextBox" Watermark="Введіть email" />

                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="12"
                        Foreground="Gray"
                        Text="Пароль" />

                    <Grid>
                        <TextBox
                            Name="PasswordTextBox"
                            x:Name="PasswordTextBox"
                            PasswordChar="•"
                            Watermark="Введіть пароль" />
                        <Button
                            Name="TogglePasswordButton"
                            x:Name="TogglePasswordButton"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="TogglePasswordButton_Click"
                            Content="👁️"
                            Cursor="Hand" />
                    </Grid>

                    <Button
                        Name="LoginButton"
                        Classes="login"
                        Click="LoginButton_Click"
                        Content="Увійти" />

                    <Button
                        Name="RegisterButton"
                        HorizontalAlignment="Center" 
                        Classes="secondary" 
                        Content="Зареєструватися" />

                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>