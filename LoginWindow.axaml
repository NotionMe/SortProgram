<Window
    x:Class="Practika2_OPAM_Ubohyi_Stanislav.LoginWindow.LoginWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="AlgoStart Login"
    Width="900"
    Height="600"
    ExtendClientAreaTitleBarHeightHint="-1"
    ExtendClientAreaToDecorationsHint="True"
    Foreground="#333"
    SystemDecorations="None"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Styles>
        <StyleInclude Source="/Styles/LoginStyles.axaml"/>
    </Window.Styles>

    <Grid>
        <!-- Close button -->
        <Button 
            Name="CloseButton" 
            Classes="CloseButton" 
            Content="✕" 
            Click="CloseWindow"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,15,15,0"/>

        <Grid ColumnDefinitions="1*,1*">
            <!-- Left side - Image/Branding -->
            <Border Grid.Column="0" Classes="BrandingPanel">
                <StackPanel VerticalAlignment="Center" Spacing="20">
                    <TextBlock Classes="BrandingTitle" Text="AlgoStart"/>
                    <TextBlock Classes="BrandingSubtitle" Text="Explore the world of sorting algorithms"/>
                    <TextBlock Text="🔄" FontSize="120" HorizontalAlignment="Center" Foreground="#FFFFFF" Opacity="0.7"/>
                </StackPanel>
            </Border>

            <!-- Right side - Login Form -->
            <Border Grid.Column="1" Classes="LoginFormPanel">
                <Grid RowDefinitions="Auto,*,Auto" Margin="40,0">
                    <TextBlock Grid.Row="0" Classes="WelcomeText" Text="Welcome Back" Margin="0,60,0,0"/>
                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="24">
                        <TextBlock Classes="FormHeader" Text="Sign in to your account"/>
                        
                        <!-- Username field -->
                        <StackPanel Spacing="8">
                            <TextBlock Classes="LabelText" Text="Username"/>
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Classes="IconContainer">
                                    <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBox Grid.Column="1" Classes="InputField" Watermark="Enter your username"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Email field -->
                        <StackPanel Spacing="8">
                            <TextBlock Classes="LabelText" Text="Email"/>
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Classes="IconContainer">
                                    <TextBlock Text="✉️" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBox Grid.Column="1" Name="EmailBox" Classes="InputField" Watermark="Enter your email"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Password field -->
                        <StackPanel Spacing="8">
                            <TextBlock Classes="LabelText" Text="Password"/>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Classes="IconContainer">
                                    <TextBlock Text="🔒" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBox Grid.Column="1" Name="PasswordBox" Classes="InputField" PasswordChar="•" Watermark="Enter your password"/>
                                <Button Grid.Column="2" Name="ShowPasswordButton" Classes="EyeButton" Click="OnTogglePasswordVisibility">
                                    <TextBlock Text="👁️" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Remember me & Forgot password -->
                        <Grid ColumnDefinitions="*,*">
                            <CheckBox Grid.Column="0" Content="Remember me" Classes="RememberCheckbox"/>
                            <TextBlock Grid.Column="1" Classes="ForgotPasswordText" Text="Forgot Password?" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <!-- Login Button -->
                        <Button Classes="LoginButton" Content="Sign In" HorizontalAlignment="Stretch" Click="LoginButton_Click"/>
                    </StackPanel>
                    
                    <!-- Footer -->
                    <TextBlock Grid.Row="2" Classes="FooterText" Text=" 2025 AlgoStart. All rights reserved." Margin="0,0,0,20"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>