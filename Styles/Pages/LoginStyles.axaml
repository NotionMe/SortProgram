<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ==================== -->
    <!-- BRANDING PANEL       -->
    <!-- ==================== -->
    <Style Selector="Border.BrandingPanel">
        <Setter Property="Background" Value="#1E1E2F"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    
    <Style Selector="TextBlock.BrandingTitle">
        <Setter Property="FontSize" Value="42"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
    
    <Style Selector="TextBlock.BrandingSubtitle">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="30,0"/>
    </Style>
    
    <!-- ==================== -->
    <!-- LOGIN FORM PANEL     -->
    <!-- ==================== -->
    <Style Selector="Border.LoginFormPanel">
        <Setter Property="Background" Value="#FFFFFF"/>
    </Style>
    
    <Style Selector="TextBlock.WelcomeText">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>
    
    <Style Selector="TextBlock.FormHeader">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
    
    <!-- ==================== -->
    <!-- LOGIN INPUT FIELDS   -->
    <!-- ==================== -->
    <Style Selector="TextBlock.LabelText">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="#505050"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
    
    <Style Selector="TextBox.InputField">
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="0,8,8,0"/>
        <Setter Property="Background" Value="#F8F8F8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
    <Style Selector="TextBox.InputField:focus">
        <Setter Property="Background" Value="#F0F0F0"/>
    </Style>
    
    <!-- ==================== -->
    <!-- LOGIN FORM ELEMENTS  -->
    <!-- ==================== -->
    <Style Selector="CheckBox.RememberCheckbox">
        <Setter Property="Foreground" Value="#505050"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    
    <Style Selector="TextBlock.ForgotPasswordText">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    
    <Style Selector="TextBlock.ForgotPasswordText:pointerover">
        <Setter Property="Foreground" Value="{StaticResource AccentDarkColor}"/>
    </Style>
    
    <Style Selector="TextBlock.FooterText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#999999"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    
    <!-- ==================== -->
    <!-- UTILITY BUTTONS      -->
    <!-- ==================== -->
    <Style Selector="Button.closeButton">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="ZIndex" Value="100"/>
    </Style>
    
    <Style Selector="Button.closeButton:pointerover">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
    </Style>
</Styles> 