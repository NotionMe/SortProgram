<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ==================== -->
    <!-- FORM CONTROL STYLES  -->
    <!-- ==================== -->
    <Style Selector="TextBox.formControl">
        <Setter Property="Height" Value="35"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource GreyMedium}"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
    
    <Style Selector="TextBox.formControl:focus">
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    
    <Style Selector="ComboBox.formControl">
        <Setter Property="Height" Value="35"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource GreyMedium}"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    
    <Style Selector="ComboBox.formControl:focus">
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    
    <!-- ==================== -->
    <!-- OTHER FORM CONTROLS  -->
    <!-- ==================== -->
    <Style Selector="CheckBox.formControl">
        <Setter Property="Margin" Value="0,5"/>
    </Style>
    
    <Style Selector="Slider.formControl">
        <Setter Property="Margin" Value="0,10"/>
    </Style>
    
    <Style Selector="ToggleSwitch">
        <Setter Property="Margin" Value="0,5"/>
        <Setter Property="OnContent" Value=""/>
        <Setter Property="OffContent" Value=""/>
    </Style>
    
    <!-- ==================== -->
    <!-- FORM LAYOUT STYLES   -->
    <!-- ==================== -->
    <Style Selector="TextBlock.formLabel">
        <Setter Property="Margin" Value="0,0,0,5"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>
    
    <Style Selector="TextBlock.formHint">
        <Setter Property="Foreground" Value="{StaticResource GreyDark}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
    </Style>
    
    <Style Selector="TextBlock.formError">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
    </Style>
    
    <Style Selector="StackPanel.formGroup">
        <Setter Property="Margin" Value="0,0,0,15"/>
    </Style>
    
    <!-- ==================== -->
    <!-- INPUT ICON STYLES    -->
    <!-- ==================== -->
    <Style Selector="Border.IconContainer">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="35"/>
        <Setter Property="Background" Value="{StaticResource GreyLight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GreyMedium}"/>
        <Setter Property="BorderThickness" Value="1,1,0,1"/>
        <Setter Property="CornerRadius" Value="4,0,0,4"/>
    </Style>
</Styles> 