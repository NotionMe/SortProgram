<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ==================== -->
    <!-- CARD STYLES          -->
    <!-- ==================== -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource LightCardBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LightBorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="Margin" Value="0,0,0,15"/>
        <Setter Property="BoxShadow" Value="0 2 4 #20000000"/>
    </Style>
    
    <!-- ==================== -->
    <!-- HEADING STYLES       -->
    <!-- ==================== -->
    <Style Selector="Border.header">
        <Setter Property="Background" Value="{StaticResource InfoBrush}"/>
    </Style>
    
    <Style Selector="TextBlock.algorithm-title">
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="TextBlock.description-title">
        <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
    </Style>
    
    <Style Selector="TextBlock.sectionTitle">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,10,0,10"/>
    </Style>
    
    <!-- ==================== -->
    <!-- PANELS STYLES        -->
    <!-- ==================== -->
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{StaticResource LightCardBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LightBorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
</Styles> 