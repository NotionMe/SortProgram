<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Branding Panel Styles -->
    <Style Selector="Border.BrandingPanel">
        <Setter Property="Background" Value="#1E1E2F"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    
    <Style Selector="TextBlock.BrandingTitle">
        <Setter Property="FontSize" Value="42"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
    
    <Style Selector="TextBlock.BrandingSubtitle">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="30,0"/>
    </Style>
    
    <!-- Login Form Panel Styles -->
    <Style Selector="Border.LoginFormPanel">
        <Setter Property="Background" Value="#FFFFFF"/>
    </Style>
    
    <Style Selector="TextBlock.WelcomeText">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>
    
    <Style Selector="TextBlock.FormHeader">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
    
    <!-- Input Field Styles -->
    <Style Selector="TextBlock.LabelText">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="#505050"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
    
    <Style Selector="Border.IconContainer">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Background" Value="#F5F5F5"/>
        <Setter Property="CornerRadius" Value="8,0,0,8"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>
    
    <Style Selector="TextBox.InputField">
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="0,8,8,0"/>
        <Setter Property="Background" Value="#F8F8F8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
    <Style Selector="TextBox.InputField:focus">
        <Setter Property="Background" Value="#F0F0F0"/>
    </Style>
    
    <!-- Button Styles -->
    <Style Selector="Button.LoginButton">
        <Setter Property="Height" Value="45"/>
        <Setter Property="Background" Value="#5a65ba"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,10,0,0"/>
    </Style>
    
    <Style Selector="Button.LoginButton:pointerover">
        <Setter Property="Background" Value="#4a55aa"/>
    </Style>
    
    <Style Selector="Button.LoginButton:pressed">
        <Setter Property="Background" Value="#3a45aa"/>
    </Style>
    
    <!-- Close Button Style -->
    <Style Selector="Button.CloseButton">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="ZIndex" Value="100"/>
    </Style>
    
    <Style Selector="Button.CloseButton:pointerover">
        <Setter Property="Foreground" Value="#FF0000"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    
    <Style Selector="Button.CloseButton:pointerover TextBlock">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Foreground" Value="#FF0000"/>
    </Style>
    
    <!-- Checkbox Style -->
    <Style Selector="CheckBox.RememberCheckbox">
        <Setter Property="Foreground" Value="#505050"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    
    <Style Selector="CheckBox.RememberCheckbox:pointerover">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Foreground" Value="#505050"/>
    </Style>
    
    <!-- Forgot Password Text Style -->
    <Style Selector="TextBlock.ForgotPasswordText">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#5a65ba"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    
    <Style Selector="TextBlock.ForgotPasswordText:pointerover">
        <Setter Property="Foreground" Value="#4a55aa"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    
    <!-- Footer Text Style -->
    <Style Selector="TextBlock.FooterText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#999999"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    
    <!-- Eye Button Styles -->
    <Style Selector="Button.EyeButton">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    
    <Style Selector="Button.EyeButton:pointerover">
        <Setter Property="Background" Value="#f0f0f0"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    
    <Style Selector="Button.EyeButton:pointerover TextBlock">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Foreground" Value="#505050"/>
    </Style>
    
    <Style Selector="Button.EyeButton:pressed">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="RenderTransform" Value="none"/>
    </Style>
    
    <Style Selector="Path.EyeIcon">
        <Setter Property="Fill" Value="#707070"/>
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Stretch" Value="Uniform"/>
    </Style>
</Styles>
